# DataKYC — Environment Configuration

# API
API_HOST=0.0.0.0
API_PORT=8002
API_RELOAD=false
API_LOG_LEVEL=info

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://datakyc:datakyc_secret@localhost:5433/datakyc

# Redis
REDIS_URL=redis://localhost:6380/0

# Spark Vision Models
GRANITE_VISION_URL=http://10.0.0.100:8004/v1
GEMMA4_URL=http://10.0.0.100:8003/v1
VISION_TIMEOUT_SECONDS=30

# Security
API_KEY_PREFIX=dkc
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars

# Tier Defaults
DEFAULT_TIER=FREE
